<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000">

        <!-- AR camera view -->
        <io.github.sceneview.ar.ARSceneView
            android:id="@+id/arSceneView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

        <com.example.smilesphere.HotspotOverlayView
            android:id="@+id/hotspotOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>


        <!-- Top status bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="16dp"
            android:layout_gravity="top">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AR Explorer 🦷"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Point camera at tooth marker card"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:background="#CC000000"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:layout_marginBottom="6dp"/>

            <!-- Sequenced-lesson progress indicator (lesson 3 brushing steps) -->
            <TextView
                android:id="@+id/tvProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Langkah 1/4"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="#CC1D9E75"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- Tooth info popup card (hidden until tap) -->
        <LinearLayout
            android:id="@+id/cardToothInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F0FBF7"
            android:padding="20dp"
            android:layout_gravity="bottom"
            android:layout_marginBottom="70dp"
            android:visibility="gone"
            android:elevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🦷 Tooth Part"
                    android:textSize="12sp"
                    android:textColor="#1D9E75"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvPartIndex"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1 / 6"
                    android:textSize="11sp"
                    android:textColor="#888888"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvToothPart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Crown"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/tvToothFunction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Function"
                android:textSize="14sp"
                android:textColor="#444444"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="14dp"/>

            <!-- Prev / Next / Close buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <Button
                    android:id="@+id/btnPrevPart"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="← Prev"
                    android:textSize="12sp"
                    android:backgroundTint="#888888"
                    android:layout_marginEnd="6dp"/>

                <Button
                    android:id="@+id/btnClosePart"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="✕ Close"
                    android:textSize="12sp"
                    android:backgroundTint="#444444"
                    android:layout_marginEnd="6dp"/>

                <Button
                    android:id="@+id/btnNextPart"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="Next →"
                    android:textSize="12sp"
                    android:backgroundTint="#1D9E75"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Bottom action button -->
        <Button
            android:id="@+id/btnDone"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_margin="16dp"
            android:text="Done — Go to Quiz →"
            android:textSize="14sp"
            android:backgroundTint="#1D9E75"/>

    </FrameLayout>

    <!-- Side drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#FFFFFF"
        app:headerLayout="@layout/drawer_header"
        app:menu="@menu/drawer_menu"
        app:itemIconTint="#1D9E75"
        app:itemTextColor="#1A1A1A"/>

</androidx.drawerlayout.widget.DrawerLayout>