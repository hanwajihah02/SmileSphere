<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_app">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp"
        android:gravity="center_horizontal">

        <LinearLayout
            android:layout_width="112dp"
            android:layout_height="112dp"
            android:background="@drawable/bg_card"
            android:gravity="center"
            android:elevation="3dp"
            android:layout_marginTop="42dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="68dp"
                android:layout_height="68dp"
                android:text="S"
                android:textSize="34sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:gravity="center"
                android:background="@drawable/bg_icon_mint"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hello explorer"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/ss_mint_dark"
            android:background="@drawable/bg_badge"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="7dp"
            android:paddingBottom="7dp"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome to"
            android:textSize="25sp"
            android:textColor="@color/ss_ink"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SmileSphere"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/ss_mint_dark"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Learn healthy habits, explore teeth in AR, and answer classroom quizzes."
            android:textSize="14sp"
            android:textColor="@color/ss_text_soft"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="32dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:background="@drawable/bg_input_modern"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="@"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/ss_sky"
                android:gravity="center"
                android:background="@drawable/bg_card_sky"
                android:layout_marginEnd="10dp"/>

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Email address"
                android:inputType="textEmailAddress"
                android:background="@null"
                android:textColor="@color/ss_ink"
                android:textColorHint="@color/ss_text_soft"
                android:textSize="14sp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:background="@drawable/bg_input_modern"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="*"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/ss_mint_dark"
                android:gravity="center"
                android:background="@drawable/bg_card_mint"
                android:layout_marginEnd="10dp"/>

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:hint="Password"
                android:inputType="textPassword"
                android:background="@null"
                android:textColor="@color/ss_ink"
                android:textColorHint="@color/ss_text_soft"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/tvTogglePassword"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="👁"
                android:textSize="16sp"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginStart="6dp"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Let's go"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:textAllCaps="false"
            android:layout_marginBottom="16dp"
            android:backgroundTint="@color/ss_mint_dark"
            app:cornerRadius="18dp" />

        <TextView
            android:id="@+id/tvGoRegister"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="New here? Create an account"
            android:textColor="@color/ss_mint_dark"
            android:textStyle="bold"
            android:textSize="13sp"
            android:padding="8dp"/>
    </LinearLayout>
</ScrollView>
