<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="188dp"
    android:orientation="vertical"
    android:gravity="bottom"
    android:padding="24dp"
    android:background="@drawable/bg_card_mint">

    <TextView
        android:layout_width="58dp"
        android:layout_height="58dp"
        android:text="S"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:gravity="center"
        android:background="@drawable/bg_icon_mint"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SmileSphere"
        android:textSize="21sp"
        android:textStyle="bold"
        android:textColor="@color/ss_ink"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="School Dental Service"
        android:textSize="13sp"
        android:textColor="@color/ss_text_soft"/>
</LinearLayout>
