<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0FBF7">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">
            <TextView
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="←"
                android:textSize="22sp"
                android:textColor="#1D9E75"
                android:padding="4dp"
                android:layout_marginEnd="12dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="New Session Setup"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"/>
        </LinearLayout>

        <!-- School emoji -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏫"
            android:textSize="48sp"
            android:layout_gravity="center"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Which school are you visiting today?"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:layout_gravity="center"
            android:gravity="center"
            android:layout_marginBottom="24dp"/>

        <!-- School dropdown label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select school from list:"
            android:textSize="13sp"
            android:textColor="#555555"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <!-- Spinner dropdown -->
        <Spinner
            android:id="@+id/spinnerSchool"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/spinner_background"
            android:paddingStart="12dp"
            android:paddingEnd="42dp"
            android:popupBackground="@color/white"
            android:layout_marginBottom="16dp"/>

        <!-- Divider -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">
            <View android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#CCCCCC"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  OR  "
                android:textSize="12sp"
                android:textColor="#888888"/>
            <View android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#CCCCCC"/>
        </LinearLayout>

        <!-- Manual entry label -->
        <TextView
            android:id="@+id/tvManualLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Type school name manually:"
            android:textSize="13sp"
            android:textColor="#555555"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:visibility="gone"/>

        <!-- Manual school name input -->
        <EditText
            android:id="@+id/etSchoolManual"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="e.g. SK Taman Maju"
            android:inputType="textCapWords"
            android:background="@drawable/bg_input_modern"
            android:textColor="@color/ss_ink"
            android:textColorHint="@color/ss_text_soft"
            android:textSize="15sp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginBottom="24dp"
            android:visibility="gone"/>

        <!-- Date label -->
        <TextView
            android:id="@+id/etDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Session date:"
            android:textSize="13sp"
            android:textColor="#555555"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <!-- Date display -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="#FFFFFF"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:orientation="horizontal"
            android:layout_marginBottom="32dp">
            <TextView
                android:id="@+id/tvDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Today"
                android:textSize="14sp"
                android:textColor="#1A1A1A"/>
            <TextView
                android:id="@+id/btnPickDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅 Change"
                android:textSize="13sp"
                android:textColor="#1D9E75"
                android:padding="4dp"/>
        </LinearLayout>

        <!-- Start button -->
        <Button
            android:id="@+id/btnStartSession"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Start Session →"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#1D9E75"/>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:visibility="gone"/>

    </LinearLayout>
</ScrollView>
